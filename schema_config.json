{
  "schema_version": "2.6",
  "total_features": 70,
  "domains": {
    "domain_1_personality": {
      "dataset_source": "big_five_personality_clean.csv",
      "features": [
        "EXT1", "EXT2", "EXT3", 
        "EST1", "EST2", "EST3", 
        "AGR1", "AGR2", "AGR3", 
        "CSN1", "CSN2", "CSN3", 
        "OPN1", "OPN2", "OPN3"
      ]
    },
    "domain_2_self_esteem": {
      "dataset_source": "rosenberg_self_esteem_clean.csv",
      "features": [
        "age",
        "gender",
        "Q1", "Q2", "Q3", "Q4", "Q5", "Q6", "Q7", "Q8", "Q9", "Q10"
      ]
    },
    "domain_3_mood_and_sleep": {
      "dataset_source": "nhanes_joined_mood_sleep.csv",
      "features": [
        "DPQ010", "DPQ020", "DPQ030", "DPQ040", "DPQ050", "DPQ060", "DPQ070", "DPQ080", "DPQ090", "DPQ100",
        "SLQ300",
        "SLQ310"
      ]
    },
    "domain_4_digital_and_social": {
      "dataset_source": "internet_phq_loneliness_clean.csv",
      "features": [
        "age",
        "gender",
        "IAT1", "IAT2", "IAT3", "IAT4", "IAT5", "IAT6", "IAT7", "IAT8", "IAT9", "IAT10",
        "loneliness1", "loneliness2", "loneliness3", "loneliness4", "loneliness5", "loneliness6"
      ]
    },
    "domain_5_occupational_burnout": {
      "dataset_source": "tech_burnout_2026_clean.csv",
      "features": [
        "age",
        "gender",
        "work_hours_per_week",
        "meetings_per_day",
        "work_life_balance_score", 
        "job_satisfaction_score",
        "deadline_pressure_score",
        "autonomy_score", 
        "stress_score",
        "social_support_score"
      ]
    },
    "domain_6_severe_clinical": {
      "dataset_source": "ocd_symptoms_clean.csv",
      "features": [
        "unwanted_thoughts",
        "repetitive_behaviors",
        "overthinking", 
        "mind_going_blank",
        "avoidance_social_activity",
        "panic",
        "hypervigilance"
      ]
    }
